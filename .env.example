# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED for Netlify background functions — generate a strong random string
INTERNAL_SECRET=generate-a-strong-random-secret-here

# Comma-separated list of allowed origins for CORS (omit for dev, set in production)
# Example: https://your-app.netlify.app,https://your-domain.com
ALLOWED_ORIGINS=

# ── Google Gemini AI (REQUIRED — context-aware UPSC/HCS translation) ─────────
# Get key from: aistudio.google.com → API Keys
GEMINI_API_KEY=
# Model: gemini-2.0-flash (fast) or gemini-2.5-pro (best quality)
GEMINI_MODEL=gemini-2.0-flash

# ── Email (for sharing translated files) ──────────────────────────────────────
# Gmail: use an App Password (Google Account → Security → App Passwords)
# Other SMTP: set host/port accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
