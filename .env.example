# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Anthropic Claude AI (optional — smarter UPSC/HCS translation) ─────────────
# Get key from: console.anthropic.com → API Keys
# Leave blank to use free Google Translate instead
ANTHROPIC_API_KEY=
# Model: claude-haiku-4-5-20251001 (fast/cheap) or claude-sonnet-4-6 (best quality)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Email (for sharing translated files) ──────────────────────────────────────
# Gmail: use an App Password (Google Account → Security → App Passwords)
# Other SMTP: set host/port accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
